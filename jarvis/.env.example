# Rocky Assistant Environment Variables
# Copy this file to .env and fill in your details

# Spotify API Credentials
# Get these from the Spotify Developer Dashboard: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# (Optional) Future additions for keys like Wolfram Alpha, OpenAI, etc.
WOLFRAM_APP_ID=your_wolfram_app_id
