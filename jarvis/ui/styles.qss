/* 
   Rocky JARVIS HUD — Phase 7 Ultimate
   Iron Man Mark 85 + Cyberpunk Glassmorphism
*/

QWidget#RockyWindow {
    background: transparent;
}

QFrame#mainPanel {
    background-color: rgba(4, 6, 14, 0.90);
    border: 1px solid rgba(0, 220, 255, 0.20);
    border-radius: 22px;
    border-bottom: 2px solid rgba(0, 220, 255, 0.35);
}

QLabel#brandLabel {
    font-family: "Segoe UI", "Inter", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 7px;
    color: rgba(0, 220, 255, 0.65);
}

QLabel#statusLabel {
    font-family: "Consolas", "Segoe UI", monospace;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 3px;
    color: rgba(0, 255, 180, 0.75);
}

/* ── Prefix labels ── */
QLabel#prefixLabel {
    font-family: "Consolas", monospace;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2px;
    color: rgba(100, 160, 255, 0.45);
    min-width: 50px;
    padding-top: 2px;
}

QLabel#prefixRocky {
    font-family: "Consolas", monospace;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2px;
    color: rgba(0, 220, 255, 0.85);
    min-width: 50px;
    padding-top: 2px;
}

/* ── Content labels ── */
QLabel#userLabel {
    font-family: "Segoe UI", "Inter", sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: rgba(160, 200, 255, 0.75);
    line-height: 1.5;
}

QLabel#aiLabel {
    font-family: "Segoe UI", "Inter", sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: rgba(240, 250, 255, 0.97);
    line-height: 1.6;
}

/* ── Info bar ── */
QLabel#infoPrefix {
    font-size: 13px;
    color: rgba(0, 220, 255, 0.5);
    min-width: 18px;
    padding-top: 1px;
}

QLabel#infoLabel {
    font-family: "Consolas", monospace;
    font-size: 10px;
    font-weight: 400;
    color: rgba(0, 220, 255, 0.4);
    line-height: 1.3;
}

/* ── Divider ── */
QFrame#divider {
    background-color: rgba(0, 220, 255, 0.12);
    max-height: 1px;
    border: none;
}

/* ── Close button ── */
QPushButton#closeBtn {
    background: transparent;
    color: rgba(0, 220, 255, 0.35);
    border: none;
    font-size: 20px;
    font-weight: 300;
    padding: 0px;
    margin: 0px;
}
QPushButton#closeBtn:hover {
    color: rgba(255, 70, 70, 1.0);
}
