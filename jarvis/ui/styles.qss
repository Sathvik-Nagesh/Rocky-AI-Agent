/* Rocky JARVIS HUD — Premium dark glassmorphism */

QWidget#RockyWindow {
    background: transparent;
}

QFrame#mainPanel {
    background-color: rgba(6, 10, 20, 0.92);
    border: 1px solid rgba(0, 200, 255, 0.15);
    border-radius: 18px;
}

QLabel#brandLabel {
    font-family: "Segoe UI";
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 5px;
    color: rgba(0, 200, 255, 0.45);
}

QLabel#statusLabel {
    font-family: "Segoe UI";
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 3px;
    color: rgba(0, 200, 255, 0.65);
}

/* YOU / ROCKY prefix labels */
QLabel#prefixLabel {
    font-family: "Segoe UI";
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    color: rgba(120, 180, 255, 0.5);
    min-width: 44px;
    padding-top: 2px;
}

QLabel#prefixRocky {
    font-family: "Segoe UI";
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    color: rgba(0, 200, 255, 0.65);
    min-width: 44px;
    padding-top: 2px;
}

QLabel#userLabel {
    font-family: "Segoe UI";
    font-size: 12px;
    color: rgba(160, 200, 255, 0.65);
    line-height: 1.4;
}

QLabel#aiLabel {
    font-family: "Segoe UI";
    font-size: 14px;
    font-weight: 400;
    color: rgba(225, 240, 255, 0.95);
    line-height: 1.5;
}

QFrame#divider {
    background-color: rgba(0, 200, 255, 0.1);
    max-height: 1px;
    border: none;
}

QPushButton#closeBtn {
    background: transparent;
    color: rgba(0, 200, 255, 0.3);
    border: none;
    font-size: 18px;
    font-weight: 300;
    padding: 0px;
    margin: 0px;
}
QPushButton#closeBtn:hover {
    color: rgba(255, 70, 70, 0.9);
}
